<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:MobileApp.ViewModels"
             xmlns:design="clr-namespace:MobileApp.ViewModels.Design"
             mc:Ignorable="d" d:DesignWidth="540" d:DesignHeight="960"
             Background="{DynamicResource Charcoal}"
             x:Class="MobileApp.Views.DataView"
             x:DataType="vm:DataViewModel">
  <Design.DataContext>
    <design:DesignDataViewModel />
  </Design.DataContext>

  <ScrollViewer>
    <StackPanel Margin="20 10 20 20" Spacing="10" Orientation="Vertical">

      <!-- Errors -->
      <Border Background="#FEF2F2"
              BorderBrush="#FECACA"
              BorderThickness="1"
              CornerRadius="8"
              Padding="16"
              IsVisible="{Binding HasErrors}">
        <ItemsControl ItemsSource="{Binding Errors}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding .}" TextWrapping="Wrap" FontWeight="SemiBold" FontSize="14" Foreground="#DC2626"/>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Border>

      <!-- Accounts -->
      <Grid ColumnDefinitions="Auto, *, Auto, Auto" Margin="0 10">
        <TextBlock Text="Accounts" VerticalAlignment="Center" Margin="0 0 5 0" FontSize="18" FontWeight="DemiBold" Foreground="{DynamicResource PureWhite}"/>

        <Button Grid.Column="2" Command="{Binding OpenAuthPageCommand}" Background="{DynamicResource Lavender}"
                Foreground="{DynamicResource Charcoal}" FontWeight="DemiBold" HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="15 0">
          <Button.Styles>
            <Style Selector="Button:pointerover /template/ ContentPresenter, Button:pressed /template/ ContentPresenter">
              <Setter Property="Background" Value="{DynamicResource PureWhite}"/>
            </Style>
          </Button.Styles>
          <PathIcon Data="{DynamicResource AddCircleRegular}"/>
        </Button>

        <Button Grid.Column="3" Command="{Binding RefreshTokenCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="{DynamicResource Lavender}">
          <PathIcon Data="{StaticResource ArrowSyncCircleRegular}" Foreground="{DynamicResource Charcoal}"/>
          <Button.Styles>
            <Style Selector="Button:pointerover /template/ ContentPresenter, Button:pressed /template/ ContentPresenter">
              <Setter Property="Background" Value="{DynamicResource PureWhite}"/>
            </Style>
          </Button.Styles>
        </Button>
      </Grid>

      <ProgressBar IsIndeterminate="True" IsVisible="{Binding Loading}" />

      <!-- Balances -->
      <ItemsControl ItemsSource="{Binding Balances}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Background="{DynamicResource PureWhite}" CornerRadius="10" Margin="0 0 0 15" Padding="15">
              <StackPanel Spacing="12">
                <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto">
                  <!-- Logo -->
                  <Border Grid.RowSpan="2" Width="64" Height="64" BorderBrush="LightGray" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                    <Border.Background>
                      <ImageBrush Source="{Binding IconSource}" Stretch="UniformToFill"/>
                    </Border.Background>
                  </Border>

                  <!-- Account Info Section -->
                  <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding AvailableAmount}" HorizontalAlignment="Right"
                             FontWeight="Bold" FontSize="22" Foreground="{DynamicResource Charcoal}"/>
                  <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Iban}"
                             HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                </Grid>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>
  </ScrollViewer>
</UserControl>
